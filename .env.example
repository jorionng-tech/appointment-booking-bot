# ──────────────────────────────────────────────────────────────────────────
# Appointment Booking Bot — environment template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# ── Twilio WhatsApp (Sandbox) (REQUIRED) ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Public URL Twilio calls for the webhook — must match the Twilio console
# EXACTLY (used for signature validation).
PUBLIC_WEBHOOK_URL=https://your-tunnel-or-domain/whatsapp/webhook

# ── Notion (REQUIRED) ──
NOTION_TOKEN=secret_your-notion-integration-token
NOTION_BOOKINGS_DB_ID=your-appointments-database-id

# ── Claude / Anthropic (REQUIRED) ──
ANTHROPIC_API_KEY=sk-ant-your-api-key
# Optional: override the intent-parsing model. Defaults to claude-opus-4-8.
# For high message volume, claude-haiku-4-5 is cheaper/faster.
# ANTHROPIC_MODEL=claude-opus-4-8

# ── Telegram admin notifications (REQUIRED) ──
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-telegram-chat-id

# ── Brevo email confirmation (OPTIONAL — bot works without it) ──
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# ── App config ──
FLASK_ENV=production
PORT=5001
